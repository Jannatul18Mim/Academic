org 100h            

.model small
.stack 100h
.data
.code
main proc
    mov ax, 1234h   ; First 16-bit number
    mov bx, 0020h   ; Second 16-bit number
    sub ax, bx      ; AX = 1214h

    ; Convert result in AX to ASCII and print
    mov bx, 10      
    mov cx, 0       
convert_loop:
    mov dx, 0       
    div bx          ; Divide AX by 10
    push dx         ; Push remainder to stack
    inc cx          
    cmp ax, 0       
    jne convert_loop 

print_loop:
    pop dx          
    add dl, 30h     ; Convert to ASCII
    mov ah, 2       
    int 21h         
    loop print_loop 

    mov ah, 4Ch     
    int 21h         
main endp
end main
